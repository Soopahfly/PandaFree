# Copy this file to .env and customize

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── SSL ───────────────────────────────────────────────
# true  → nginx terminates TLS using certs in ./ssl/
# false → nginx listens on HTTP port 80 only (use this behind
#         an upstream reverse proxy that already handles SSL)
SSL_ENABLED=true
